# Absolute or relative path to the workspace root (parent of all project folders)
WORKSPACE_PATH=..

# GitHub personal access token — passed to the PHP container for Composer.
# Required for private repos and to avoid GitHub API rate limiting (60 req/h → 5000 req/h).
GITHUB_TOKEN=your_github_token_here

# db-sync: "name:remote_path" separated by commas
DB_SYNC_DATABASES="db_name:/var/www/proyect-name/shared/var/db_backups/original"
DB_SYNC_SERVERS="server.prod1,server.staging1"
