# Absolute or relative path to the workspace root (parent of all project folders)
WORKSPACE_PATH=..

# GitHub personal access token — passed to the PHP container for Composer.
# Required for private repos and to avoid GitHub API rate limiting (60 req/h → 5000 req/h).
GITHUB_TOKEN=your_github_token_here

# db-sync: comma-separated database entries.
# Per entry, four formats are accepted:
#   1) name:path                          -> engine=mysql, server picked from DB_SYNC_SERVERS
#   2) name:engine:path                   -> server picked from DB_SYNC_SERVERS
#   3) name:engine:server:path            -> fully bound, no server prompt
#   4) name:engine:srvA|srvB:path         -> prompts to pick among the listed servers
# engine: mysql | postgres
DB_SYNC_DATABASES="splid:mysql:splid.prod1:/var/www/splid/shared/var/db_backups/original,bricket:postgres:tk.prod1:/var/www/bricket/shared/var/db_backups/original"

# Servers used when a DB entry does not bind one explicitly.
DB_SYNC_SERVERS="server.prod1,server.staging1"
